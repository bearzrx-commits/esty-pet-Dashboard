{
  "name": "etsy-admin",
  "version": "1.0.0",
  "description": "Etsy 店铺后台管理系统",
  "private": true,
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev:server": "cd server && node index.js",
    "dev:client": "cd client && npx react-scripts start",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm install && npm run build"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  }
}
